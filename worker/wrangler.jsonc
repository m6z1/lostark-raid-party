{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lostark-raid-party-api",
  "main": "src/index.js",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "vars": {
    "ALLOWED_ORIGINS": "https://m6z1.github.io,http://127.0.0.1:8766,http://localhost:8766"
  },
  "secrets": {
    "required": ["LOSTARK_API_KEY"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
